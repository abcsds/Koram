# Copy to .env (gitignored) for local development.
# In production prefer a real secret manager or pass these via your container runtime.

# Immich API key. Required permissions:
#   album.create, album.read, album.update,
#   asset.read, asset.upload, asset.view, asset.download,
#   person.read, server.about
IMMICH_API_KEY=

# Base URL of your Immich server. The plugin appends `/api` if it isn't present.
# Examples:
#   http://immich.local:2283
#   https://immich.example.com
IMMICH_BASE_URL=
